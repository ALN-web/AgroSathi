# ──────────────────────────────────────────────
# AgroSathi — Crop Prediction Service
# ──────────────────────────────────────────────

# Server
CROP_PREDICTION_PORT=8010
NODE_ENV=development

# Python ML Bridge
PYTHON_EXECUTABLE=python3
PYTHON_SCRIPTS_PATH=./python/scripts
ML_MODEL_PATH=./python/model/crop_model.pkl
ML_SCALER_PATH=./python/model/scaler.pkl
ML_ENCODER_PATH=./python/model/label_encoder.pkl

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Uploads / Temp
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
RESPONSE_DIR=./responses
MAX_FILE_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
