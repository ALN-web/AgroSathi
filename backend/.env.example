# =========================================================
# AGROSATHI ENTERPRISE PRODUCTION ENVIRONMENT CONFIGURATION
# =========================================================

# Application Standard Settings
NODE_ENV=production
PORT=8000
API_VERSION=v1

# PostgreSQL Database Configuration (Prisma Connection URL)
DATABASE_URL="postgresql://postgres:postgres_secure_pass@localhost:5432/agrosathi_production?schema=public&sslmode=prefer"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=agrosathi_production

# Redis Cache Cluster Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL="redis://localhost:6379/0"

# Authentication & Security (JWT & Refresh Tokens)
JWT_SECRET="enterprise-super-secure-jwt-secret-key-agrosathi-2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="enterprise-super-secure-refresh-token-secret-agrosathi-2026"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS & Security Headers
CORS_ORIGIN="https://app.agrosathi.com,http://localhost:5173,http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Service Port Mapping
GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
FARM_SERVICE_PORT=8002
WEATHER_SERVICE_PORT=8003
MARKET_SERVICE_PORT=8004
NOTIFICATION_SERVICE_PORT=8005

# AI Python FastAPI Services Host/Ports
AI_CROP_PREDICTION_URL="http://localhost:8080/api/v1/crop-prediction"
AI_SOIL_ANALYSIS_URL="http://localhost:8081/api/v1/soil-analysis"
AI_YIELD_PREDICTION_URL="http://localhost:8082/api/v1/yield-prediction"
AI_RECOMMENDATION_ENGINE_URL="http://localhost:8083/api/v1/recommendations"
